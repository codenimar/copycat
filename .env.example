# Binance API credentials
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Use Binance testnet instead of live trading (recommended for testing)
BINANCE_TESTNET=true

# Bot trading settings
# Maximum fraction of account balance to use per trade (0.0 to 1.0)
MAX_POSITION_SIZE=0.05
# Maximum number of concurrent open positions
MAX_OPEN_POSITIONS=10
# Leverage for futures trades (1–20 recommended)
FUTURES_LEVERAGE=5
# How often to sync positions with leaders (seconds)
SYNC_INTERVAL=60

# Leaderboard settings
# Number of top traders to follow from Binance Leaderboard
LEADERBOARD_TOP_N=5
# Minimum ROI (%) a trader must have to be followed
LEADERBOARD_MIN_ROI=50.0
# Minimum number of days a trader must have been active
LEADERBOARD_MIN_DAYS=30
# Period for leaderboard ranking: DAILY, WEEKLY, MONTHLY, ALL_TIME
LEADERBOARD_PERIOD=MONTHLY
